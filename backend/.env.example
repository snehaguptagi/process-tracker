# Copy to backend/.env (gitignored). All optional.

# Enables real Claude-powered next-step recommendations. Without it, the panel
# uses a deterministic heuristic over the same sourced knowledge base, so the app
# works with no key.
ANTHROPIC_API_KEY=

# Override the model used for recommendations (default: claude-opus-4-8).
# FZH_MODEL=claude-haiku-4-5

# Override where the SQLite profile file lives (default: backend/founder.db).
# FZH_DB_PATH=./founder.db
