# Copy to backend/.env (gitignored). All optional.

# Enables real Claude-powered AI insights. Without it, the insights panel uses a
# deterministic heuristic over the same metrics, so the app works with no key.
ANTHROPIC_API_KEY=

# Override the model used for insights (default: claude-opus-4-8).
# PT_MODEL=claude-haiku-4-5

# Override where the SQLite file lives (default: backend/process_tracker.db).
# PT_DB_PATH=./process_tracker.db
